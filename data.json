 "bios": {
  "dt": {
   "name": "Dream Theater",
   "formed": "Boston, EUA · 1985",
   "summary": "Pioneiros do metal progressivo, fundados como Majesty por John Petrucci, John Myung e Mike Portnoy enquanto estudavam na Berklee. Conhecidos pela técnica virtuosa, compassos complexos e álbuns conceptuais.",
   "members": [
    "James LaBrie — voz",
    "John Petrucci — guitarra",
    "John Myung — baixo",
    "Jordan Rudess — teclados",
    "Mike Portnoy — bateria (regressou em 2023)"
   ],
   "trivia": [
    "'Parasomnia' (2025) foi o primeiro álbum com Mike Portnoy desde 2009.",
    "Venceram o primeiro Grammy em 2022 (Melhor Performance Metal, 'The Alien').",
    "O nome vem de um antigo cinema em Monterey, Califórnia.",
    "Mike Mangini foi o baterista entre 2010 e 2023."
   ]
  },
  "st": {
   "name": "Sleep Token",
   "formed": "Reino Unido · 2016",
   "summary": "Coletivo mascarado e anónimo que funde metal, pop, R&B e ambient, liderado pela figura 'Vessel'. Construíram um culto em torno da divindade fictícia 'Sleep', a quem dizem servir.",
   "members": [
    "Vessel — voz e instrumentos",
    "II — bateria",
    "III — baixo",
    "IV — guitarra"
   ],
   "trivia": [
    "'Even in Arcadia' (2025) deu-lhes os primeiros nº1 no Reino Unido e nos EUA.",
    "A identidade dos membros permanece oficialmente secreta.",
    "Estrearam-se como cabeças de cartaz no Download Festival em 2025.",
    "Cada era do grupo é marcada por uma máscara diferente de Vessel."
   ]
  }
 }
